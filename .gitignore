# ─────────────── Harness (运行时 / 运行目录) ───────────────
# 运行时工作目录（IsolatedPaths 拷贝 .claude 到这里，不入库）
.harness/
.harness-workdir/

# PyInstaller 中间产物与分发产物
build/
dist/
*.spec
!packaging/*.spec          # packaging/ 下的 .spec 是源文件，保留

# 环境变量 / 秘密 —— 实际 .env 绝不入库；.env.example 是模板，可入库
.env
.env.local
.env.*.local

# ─────────────── Python ───────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
/env/
*.egg-info/
.eggs/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# 测试 / 覆盖率
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.nox/
.hypothesis/
.mypy_cache/
.ruff_cache/
mutants/

# ─────────────── Node / Vite / apps/ui ───────────────
node_modules/
apps/ui/node_modules/
apps/ui/dist/
apps/ui/.vite/
apps/ui/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
apps/ui/test-results/
apps/ui/playwright-report/

# ─────────────── IDE / OS ───────────────
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─────────────── 日志 / 临时 ───────────────
/tmp/svc-*.log
/tmp/svc-*.pid
*.log
logs/

# ─────────────── 本地参考物料（不入库） ───────────────
reference/
docs/plans/参考.jpg

# ─────────────── Claude Code 运行时（不入库） ───────────────
.claude/
